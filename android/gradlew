#!/bin/sh
APP_HOME=$(cd "${0%/*}" && pwd)
CLASSPATH=$APP_HOME/gradle/wrapper/gradle-wrapper.jar

if [ ! -f "$CLASSPATH" ]; then
  echo "Downloading Gradle wrapper JAR..."
  curl -sL "https://github.com/gradle/gradle/raw/v8.3.0/gradle/wrapper/gradle-wrapper.jar" -o "$CLASSPATH"
fi

exec "$JAVA_HOME/bin/java" \
    -Xmx64m \
    -Xms64m \
    -Dorg.gradle.appname="$0" \
    -classpath "$CLASSPATH" \
    org.gradle.wrapper.GradleWrapperMain \
    "$@"
